# AI Vector — environment template.
#
# Copy to `.env` at the repo root and fill in real values for local dev.
# `.env` is gitignored. In CI, these are injected as GitHub repo secrets,
# not via this file.
#
# Consumed by: src/run.py (loads via python-dotenv), then read from
# os.environ by src/rank.py and src/summarise.py.
#
# NOTE: Embeddings are NOT configured here — they run from a local
# HuggingFace model loaded in-process by src/cluster.py. See
# docs/internal/DESIGN.md → "LLM endpoint configuration" for the full contract.

# --- Required ---------------------------------------------------------------

# Provider/protocol id. One of: anthropic | bedrock | openai | litellm | ollama
# - anthropic + bedrock use native SDKs.
# - openai/litellm/ollama share the OpenAI-compatible Chat Completions path
#   (any gateway speaking that protocol works — Together, Groq, vLLM, etc.).
LLM_PROVIDER=anthropic

# Base URL of the LLM API.
# Examples:
#   anthropic : https://api.anthropic.com
#   bedrock   : https://bedrock-runtime.us-east-1.amazonaws.com
#   openai    : https://api.openai.com/v1
#   litellm   : http://localhost:4000/v1   (proxy default)
#   ollama    : http://localhost:11434/v1  (OpenAI-compat mode)
LLM_ENDPOINT=https://api.anthropic.com

# Authentication key / token. SECRET — never log, never commit.
# For Bedrock with ambient AWS creds you may leave this blank.
# For Ollama on localhost the API key may be unused (leave blank).
LLM_API_KEY=replace-me

# Model identifier as the provider expects it.
# Examples:
#   anthropic : claude-sonnet-4-6   (recommended default — fast + capable)
#   anthropic : claude-opus-4-7     (higher quality, slower, ~5x cost)
#   bedrock   : anthropic.claude-sonnet-4-6-v1:0
#   openai    : gpt-4o
#   litellm   : whatever_alias_your_proxy_maps  (e.g. claude-sonnet-4-6)
#   ollama    : llama3.1:70b
LLM_MODEL=claude-sonnet-4-6

# --- Optional ---------------------------------------------------------------

# Per-call wall-clock timeout (seconds). Default: 60
LLM_TIMEOUT_SECONDS=60

# Temperature for rank.py. Low for stability across re-runs. Default: 0.2
LLM_TEMPERATURE_RANK=0.2

# Temperature for summarise.py. Higher to give voice texture room. Default: 0.6
LLM_TEMPERATURE_SUMMARISE=0.6
