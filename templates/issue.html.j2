<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ brand.name }} {% if issue.display_number %}&middot; Issue No. {{ issue.display_number }} {% else %}(preview) {% endif %}&middot; {{ issue.date.strftime('%d %B %Y') }}</title>
  <meta name="description" content="{{ brand.tagline }} {{ brand.description }}">
  <meta name="theme-color" content="#0c0c0c">
  <link rel="icon" type="image/svg+xml" href="../favicon.svg">
  <link rel="mask-icon" href="../favicon.svg" color="#e6452f">
  <link rel="stylesheet" href="../fonts/fonts.css">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body {
      margin: 0;
      padding: 0;
      background: #fbfaf6;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      text-rendering: optimizeLegibility;
    }
    body {
      font-family: "Inter Tight", -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      color: #1a1a17;
    }

    /* ── shell ─────────────────────────────────────────────── */
    .av-shell {
      font-family: "Inter Tight", "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      font-size: 17px;
      line-height: 1.7;
      color: #1a1a17;
      background: #ffffff;
      max-width: 820px;
      margin: 0 auto;
      padding: 72px 88px 80px;
      letter-spacing: -0.003em;
      font-feature-settings: "kern", "liga", "calt";
      box-shadow: 0 1px 3px rgba(12,12,12,0.04), 0 12px 60px rgba(12,12,12,0.06);
    }

    /* ── duplicate-risk gate (staging preview only) ─────────── */
    .av-dup-gate {
      border: 2px solid #b00020;
      border-left-width: 8px;
      background: #fff5f5;
      border-radius: 6px;
      padding: 18px 22px;
      margin-bottom: 32px;
      color: #5c0010;
      font-family: "Inter Tight", system-ui, sans-serif;
    }
    .av-dup-gate-head {
      font-weight: 800;
      font-size: 16px;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      margin-bottom: 8px;
      color: #b00020;
    }
    .av-dup-gate-body, .av-dup-gate-remedy {
      font-size: 14px;
      line-height: 1.5;
      margin: 0 0 8px;
    }
    .av-dup-gate-cmds {
      margin: 0;
      padding: 12px 14px;
      background: #2b0008;
      color: #ffd9dd;
      border-radius: 4px;
      font-family: "SFMono-Regular", ui-monospace, Menlo, monospace;
      font-size: 13px;
      line-height: 1.6;
      overflow-x: auto;
    }

    /* ── masthead ──────────────────────────────────────────── */
    .av-masthead {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 32px;
      padding-bottom: 20px;
      border-bottom: 1px solid #0c0c0c;
      margin-bottom: 36px;
    }
    .av-brand {
      font-family: "Big Shoulders Display", "Inter Tight", sans-serif;
      font-size: 60px;
      font-weight: 800;
      letter-spacing: -0.005em;
      line-height: 0.85;
      color: #0c0c0c;
      text-transform: uppercase;
    }
    .av-brand-slash { color: #e6452f; margin: 0 2px; }
    .av-mast-meta {
      font-family: "JetBrains Mono", ui-monospace, "SF Mono", Menlo, Consolas, monospace;
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #5a5a55;
      text-align: right;
      line-height: 1.7;
    }
    .av-mast-archive {
      display: inline-block;
      margin-top: 4px;
      color: #e6452f;
      font-weight: 600;
      text-decoration: none;
      border-bottom: 1px solid rgba(230,69,47,0.35);
    }
    .av-mast-archive:hover { border-bottom-color: #e6452f; }

    /* ── tagline ───────────────────────────────────────────── */
    .av-tagline {
      font-family: "DM Serif Display", "Source Serif 4", Georgia, serif;
      font-style: italic;
      font-size: 22px;
      color: #1a1a17;
      margin: 0 0 32px;
      letter-spacing: -0.01em;
      line-height: 1.3;
    }
    .av-tagline-mark { color: #e6452f; margin-right: 12px; }

    /* ── pulse ─────────────────────────────────────────────── */
    .av-pulse {
      margin: 0 0 56px;
      padding: 32px 32px 28px;
      background: #fdf4f1;
      border-left: 3px solid #e6452f;
    }
    .av-pulse-label {
      font-family: "Inter Tight", sans-serif;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #e6452f;
      margin: 0 0 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .av-pulse-bar { width: 32px; height: 2px; background: #e6452f; }
    .av-pulse-title {
      font-family: "Inter Tight", -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: 34px;
      font-weight: 700;
      letter-spacing: -0.028em;
      line-height: 1.15;
      margin: 0 0 22px;
      color: #0c0c0c;
      text-wrap: balance;
      max-width: 26ch;
    }
    .av-pulse-body {
      font-size: 18px;
      line-height: 1.65;
      color: #2a2a26;
      margin: 0 0 18px;
      max-width: 38em;
      text-wrap: pretty;
    }
    .av-pulse-meta {
      display: flex;
      align-items: center;
      gap: 14px;
      font-size: 13px;
      color: #6a6a64;
      flex-wrap: wrap;
    }
    .av-pulse-link {
      color: #e6452f;
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
      font-weight: 600;
    }

    /* ── section ───────────────────────────────────────────── */
    .av-section-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 20px;
      padding-top: 32px;
      padding-bottom: 12px;
      border-bottom: 1px solid #0c0c0c;
      margin: 0 0 28px;
    }
    .av-section-title-wrap {
      display: flex;
      align-items: baseline;
      gap: 16px;
    }
    .av-section-title {
      font-family: "Inter Tight", sans-serif;
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.025em;
      line-height: 1.1;
      margin: 0;
      color: #0c0c0c;
    }
    .av-section-count {
      font-family: "JetBrains Mono", monospace;
      font-size: 11px;
      color: #6a6a64;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    /* ── stories ───────────────────────────────────────────── */
    .av-story { margin: 0 0 36px; }
    .av-story-title {
      font-family: "Inter Tight", sans-serif;
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.025em;
      line-height: 1.2;
      margin: 0 0 10px;
      color: #0c0c0c;
      text-wrap: balance;
      max-width: 28em;
    }
    .av-story-body {
      font-size: 17px;
      line-height: 1.7;
      color: #2a2a26;
      margin: 0 0 14px;
      max-width: 38em;
      text-wrap: pretty;
    }
    .av-story-foot {
      display: flex;
      align-items: center;
      gap: 14px;
      font-size: 13px;
      color: #6a6a64;
      flex-wrap: wrap;
    }
    .av-story-src {
      color: #e6452f;
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
      font-weight: 500;
    }

    /* ── pills ─────────────────────────────────────────────── */
    .av-pill {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      border-radius: 999px;
      font-family: "Inter Tight", sans-serif;
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      line-height: 1.3;
    }
    .av-pill-act     { color: #8a5448; background: #f5ecea; }
    .av-pill-try     { color: #4f7a5d; background: #ecf2ed; }
    .av-pill-read    { color: #5a7090; background: #eef1f6; }
    .av-pill-watch   { color: #6a6a64; background: #f0efec; }
    .av-pill-discuss { color: #8a7548; background: #f4eee2; }

    /* ── section intro paragraph ───────────────────────────── */
    .av-section-intro {
      font-size: 17px;
      line-height: 1.6;
      color: #3a3a36;
      margin: 0 0 36px;
      max-width: 40em;
      text-wrap: pretty;
    }
    .av-section-intro-strong {
      color: #0c0c0c;
      font-weight: 700;
    }

    /* ── Currents (terse) ─────────────────────────────────── */
    .av-section.currents .av-story { margin: 0 0 22px; }
    .av-section.currents .av-story-body { font-size: 16px; }
    /* legacy alias for archived issues still carrying on_the_radar class */
    .av-section.on_the_radar .av-story { margin: 0 0 22px; }
    .av-section.on_the_radar .av-story-body { font-size: 16px; }

    /* ── verify flags (staging preview only) ──────────────── */
    .av-verify-flag {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 2px 8px;
      border-radius: 4px;
      font-family: "Inter Tight", system-ui, sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: #7a3800;
      background: #fff3e0;
      border: 1px solid #f0a050;
      white-space: nowrap;
    }
    .av-verify-flag--headline {
      color: #6a0000;
      background: #fff0f0;
      border-color: #e07070;
    }

    /* ── footer ────────────────────────────────────────────── */
    .av-footer {
      margin-top: 56px;
      padding-top: 24px;
      border-top: 1px solid #0c0c0c;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
      font-family: "JetBrains Mono", monospace;
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #6a6a64;
    }
    .av-footer-build {
      color: #a5a5a0;
      letter-spacing: 0.1em;
      white-space: nowrap;
    }
    .av-about {
      margin-top: 12px;
      font-size: 13px;
      color: #8a8a85;
      line-height: 1.6;
      max-width: 60em;
    }
    .av-archive-link {
      color: #6a6a64;
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
    }

    /* ── responsive ────────────────────────────────────────── */
    @media (max-width: 720px) {
      .av-shell { padding: 36px 24px 48px; }
      .av-brand { font-size: 42px; }
      .av-mast-meta { font-size: 10px; letter-spacing: 0.1em; }
      .av-tagline { font-size: 19px; }
      .av-pulse { padding: 24px 22px 22px; }
      .av-pulse-title { font-size: 26px; }
      .av-pulse-body { font-size: 17px; }
      .av-section-title { font-size: 22px; }
      .av-story-title { font-size: 20px; }
      .av-masthead { flex-direction: column; align-items: flex-start; gap: 16px; }
      .av-mast-meta { text-align: left; }
    }
  </style>
</head>
<body>
  <article class="av-shell">
    {% if dup_risk_dates %}
    <aside class="av-dup-gate" role="alert">
      <div class="av-dup-gate-head">&#9888; Duplicate risk &mdash; do not publish as-is</div>
      <p class="av-dup-gate-body">
        {{ dup_risk_dates|length }} earlier issue{{ '' if dup_risk_dates|length == 1 else 's' }}
        ({{ dup_risk_dates|join(', ') }}) {{ 'is' if dup_risk_dates|length == 1 else 'are' }}
        staged but <strong>not yet released</strong>. Cross-time dedup reads the released
        archive only, so it could not see {{ 'it' if dup_risk_dates|length == 1 else 'them' }} &mdash;
        this issue may repeat stories already covered there.
      </p>
      <p class="av-dup-gate-remedy">
        <strong>Remedy:</strong> release the earlier issue{{ '' if dup_risk_dates|length == 1 else 's' }}
        oldest-first, then re-run this date so dedup can see {{ 'it' if dup_risk_dates|length == 1 else 'them' }}:
      </p>
      <pre class="av-dup-gate-cmds">{% for d in dup_risk_dates %}aiv release --date {{ d }}
{% endfor %}aiv run --date {{ issue.date.isoformat() }}</pre>
    </aside>
    {% endif %}
    <header class="av-masthead">
      <h1 class="av-brand">{{ brand.wordmark.lead }}<span class="av-brand-slash">/</span>{{ brand.wordmark.tail }}</h1>
      <div class="av-mast-meta">
        <div>{{ issue.date.strftime('%A, %d %B %Y') }}</div>
        <div>
          {%- if issue.display_number -%}
            Issue No. {{ issue.display_number }}
          {%- else -%}
            Preview &middot; staging
          {%- endif -%}
          {%- if read_minutes %} &middot; ~{{ read_minutes }} min read{% endif -%}
        </div>
        <div><a class="av-mast-archive" href="../index.html">All Issues &rarr;</a></div>
      </div>
    </header>

    <p class="av-tagline">
      <span class="av-tagline-mark">&mdash;</span>
      {{ brand.tagline }}
    </p>

    {# ── Pulse ───────────────────────────────────────────── #}
    {% set p = issue.pulse.stories[0] %}
    <section class="av-pulse">
      <div class="av-pulse-label">
        <span class="av-pulse-bar"></span>
        <span>The Pulse &middot; Story of the day</span>
      </div>
      <h2 class="av-pulse-title">{{ p.headline }}</h2>
      <p class="av-pulse-body">{{ p.summary }}</p>
      <div class="av-pulse-meta">
        {% for url in p.source_urls %}
          <a class="av-pulse-link" href="{{ url }}">{{ url | source_label }}&nbsp;&rarr;</a>
        {% endfor %}
        {% if show_verify_flags and p.verification %}
          {% if p.verification.headline_flagged %}
            <span class="av-verify-flag av-verify-flag--headline" title="Headline claim flagged by advisory verifier">&#9888; headline claim flagged</span>
          {% elif p.verification.has_contradiction %}
            <span class="av-verify-flag av-verify-flag--headline" title="Contradicted claim detected by advisory verifier">&#9888; contradicted</span>
          {% elif p.verification.has_unsupported %}
            <span class="av-verify-flag" title="Unsupported claim detected by advisory verifier">&#9888; unsupported claim</span>
          {% endif %}
        {% endif %}
      </div>
    </section>

    {# ── Remaining sections ─────────────────────────────── #}
    {% for section in issue.sections %}
      {% if section.stories %}
        <div class="av-section {{ section.name }}">
          <div class="av-section-head">
            <div class="av-section-title-wrap">
              <h2 class="av-section-title">{{ section_title(section.name) }}</h2>
            </div>
            <span class="av-section-count">{{ section.stories|length }} {% if section.name in ('currents', 'on_the_radar') %}{{ 'item' if section.stories|length == 1 else 'items' }}{% else %}{{ 'story' if section.stories|length == 1 else 'stories' }}{% endif %}</span>
          </div>
          {% if section.intro_lead or section.intro_body %}
            <p class="av-section-intro">
              {%- if section.intro_lead %}<span class="av-section-intro-strong">{{ section.intro_lead }}</span> {% endif -%}
              {{ section.intro_body or '' }}
            </p>
          {% endif %}
          {% for story in section.stories %}
            <article class="av-story">
              <h3 class="av-story-title">{{ story.headline }}</h3>
              <p class="av-story-body">{{ story.summary }}</p>
              <div class="av-story-foot">
                {% if story.signal %}
                  <span class="av-pill av-pill-{{ story.signal }}">{{ story.signal }}</span>
                {% endif %}
                {% for url in story.source_urls %}
                  <a class="av-story-src" href="{{ url }}">{{ url | source_label }}&nbsp;&rarr;</a>
                {% endfor %}
                {% if show_verify_flags and story.verification %}
                  {% if story.verification.headline_flagged %}
                    <span class="av-verify-flag av-verify-flag--headline" title="Headline claim flagged by advisory verifier">&#9888; headline claim flagged</span>
                  {% elif story.verification.has_contradiction %}
                    <span class="av-verify-flag av-verify-flag--headline" title="Contradicted claim detected by advisory verifier">&#9888; contradicted</span>
                  {% elif story.verification.has_unsupported %}
                    <span class="av-verify-flag" title="Unsupported claim detected by advisory verifier">&#9888; unsupported claim</span>
                  {% endif %}
                {% endif %}
              </div>
            </article>
          {% endfor %}
        </div>
      {% endif %}
    {% endfor %}

    <footer class="av-footer">
      <span>{{ brand.name }} &middot; {{ issue.author if issue.author is defined else brand.author }} &middot; {{ issue.date.strftime('%d %B %Y') }} &middot; <a class="av-archive-link" href="../index.html">all issues &rarr;</a></span>
      <span class="av-footer-build">Compiled {{ issue.generated_at | aest }}</span>
    </footer>
    <p class="av-about">
      A daily AI newsletter with a financial-services lens. Curated, not aggregated. AI-drafted, human-ratified.
    </p>
  </article>
</body>
</html>
