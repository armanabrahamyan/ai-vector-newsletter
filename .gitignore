# Secrets — never commit. The repo ships a `.env.example` template instead.
.env
.env.*
!.env.example

# Python
__pycache__/
*.pyc
*.egg-info/

# Virtualenvs
.venv/

# Local Claude Code settings (per-machine; not shared via git).
# The `.local.json` suffix is Claude Code's convention for local-only config.
.claude/settings.local.json

# Eval reports — generated each time `python -m evals.run_evals` runs.
# The harness + fixtures are tracked; outputs are not.
# Exception: evals/reports/weekly/ is curated (behavioural-integrity notes) and IS tracked.
evals/reports/
!evals/reports/weekly/
!evals/reports/weekly/*.md

# LLM judge cache — rebuildable from artifacts + prompts; never commit.
evals/judge/cache/*
!evals/judge/cache/.gitkeep

# Drift baselines — per-day snapshots rebuilt on each run; never commit.
evals/drift/baselines/*
!evals/drift/baselines/.gitkeep

# Staging archive — transient working state for not-yet-released issues.
# Canonical archives at data/YYYY-MM-DD/ ARE tracked (the record of what shipped).
data/staging/

# Local embedding caches / sidecars (per Retrieval Engineer; rebuildable).
# Note: covers data/released/<date>/embeddings/ and data/staging/<date>/embeddings/.
data/embeddings/
data/released/*/embeddings/
data/staging/*/embeddings/

# Staging HTML — transient (re-rendered every staging run).
# docs/index.html and docs/released/*.html ARE tracked (released issues).
docs/staging/

# macOS noise
.DS_Store

# Scratch / throwaway working notes (rendered prompts, experiments,
# extracted artifact dumps). Not history-worthy. The directory itself
# is tracked via _scratch/.gitkeep so it exists in fresh clones.
_scratch/*
!_scratch/.gitkeep
